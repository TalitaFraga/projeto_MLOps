# Dataset
KAGGLE_DATASET_ID= # Kaggle dataset identifier, for example: owner/dataset-name
RAW_DATA_DIR= # Directory where the raw dataset file will be stored
RAW_DATA_PATH= # Full path for the raw CSV file
PROCESSED_DATA_PATH= # Full path for the processed CSV file

# Transform
CATEGORICAL_COLS= # Comma-separated categorical columns to encode with one-hot encoding
DROP_COLUMNS= # Comma-separated columns to remove from the dataset

# Training
TARGET_COLUMN= # Name of the target column used in model training
TEST_SIZE= # Test split proportion, for example: 0.3
RANDOM_STATE= # Random seed used for reproducibility, for example: 42

# Output
MODEL_DIR= # Directory where trained models will be saved
METRICS_DIR= # Directory where metrics files will be saved